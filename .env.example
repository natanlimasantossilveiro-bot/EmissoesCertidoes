# Chave usada pra assinar os tokens JWT de login — gere uma com
# `openssl rand -hex 32`. Obrigatória (sem ela, ninguém consegue logar).
JWT_SECRET_KEY=

# Credenciais do admin criado automaticamente na primeira vez que o
# Gateway sobe com um banco vazio (bootstrap). Depois de logar a
# primeira vez, use o painel de admin pra criar os demais usuários —
# essas variáveis só importam nesse primeiro boot.
ADMIN_EMAIL=
ADMIN_SENHA_INICIAL=

# RabbitMQ
RABBITMQ_URL=amqp://guest:guest@localhost:5672/

# Banco de dados central
DATABASE_URL=mysql+pymysql://root:root@localhost:3306/certidoes

# Storage de evidências: "local" ou "s3"
STORAGE_BACKEND=local
STORAGE_LOCAL_PATH=/data/evidencias

# Só necessário se STORAGE_BACKEND=s3 (ex: MinIO)
S3_ENDPOINT_URL=
S3_BUCKET=certidoes-evidencias
S3_ACCESS_KEY=
S3_SECRET_KEY=

# 2captcha (usado pelos workers que dependem de captcha, ex: atendenet)
TWOCAPTCHA_API_KEY=

# Navegador
BROWSER_HEADLESS=true
BROWSER_DOWNLOAD_DIR=/data/downloads

MAX_TENTATIVAS=3
