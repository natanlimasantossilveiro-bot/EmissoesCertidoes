# Chave de acesso ao Gateway (header X-API-Key). Deixe em branco pra
# desativar a checagem (útil em dev local) — gere uma de verdade antes de
# expor o Gateway além da rede local, ex: `openssl rand -hex 32`
GATEWAY_API_KEY=

# RabbitMQ
RABBITMQ_URL=amqp://guest:guest@localhost:5672/

# Banco de dados central
DATABASE_URL=mysql+pymysql://root:root@localhost:3306/certidoes

# Storage de evidências: "local" ou "s3"
STORAGE_BACKEND=local
STORAGE_LOCAL_PATH=/data/evidencias

# Só necessário se STORAGE_BACKEND=s3 (ex: MinIO)
S3_ENDPOINT_URL=
S3_BUCKET=certidoes-evidencias
S3_ACCESS_KEY=
S3_SECRET_KEY=

# 2captcha (usado pelos workers que dependem de captcha, ex: atendenet)
TWOCAPTCHA_API_KEY=

# Navegador
BROWSER_HEADLESS=true
BROWSER_DOWNLOAD_DIR=/data/downloads

MAX_TENTATIVAS=3
